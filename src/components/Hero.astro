---
// Hero fotografica full-bleed — logo + testo a SINISTRA su sfumatura scura.
// Scrollando, il logo si rimpicciolisce e "passa" nell'header.
---
<section class="hero" id="hero">
  <picture class="hero-pic">
    <source srcset="/foto/hero.webp" type="image/webp" />
    <img class="hero-img" src="/foto/hero.jpg" alt="Dixie & Co. dal vivo" fetchpriority="high" width="2400" height="1290" />
  </picture>
  <div class="hero-scrim"></div>

  <div class="container hero-wrap">
    <div class="hero-center" id="heroCenter">
      <h1 class="sr-only">Dixie &amp; Co. — band di jazz, swing e dixieland a Salerno per eventi, cerimonie e concerti</h1>
      <img class="hero-logo" id="heroLogo" src="/img/logo-stretto.png" alt="Dixie & Co." width="1275" height="358" />
      <p class="hero-kicker script">straw hats &amp; stripes · dal 2013</p>
      <p class="hero-tag">Jazz · Dixieland · Rock'n'Roll — da Salerno</p>
    </div>
  </div>

  <a href="#band" class="hero-scroll" aria-label="Scorri">
    <span class="hero-scroll-dot"></span>
  </a>
</section>

<style>
  .hero{position:relative;min-height:100svh;display:flex;align-items:center;
    overflow:hidden;background:var(--color-ink)}
  .hero-pic{position:absolute;inset:0}
  .hero-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:64% 42%}
  .hero-scrim{position:absolute;inset:0;
    background:
      linear-gradient(90deg, oklch(10% 0.02 60 /.94) 0%, oklch(12% 0.02 60 /.82) 26%, oklch(13% 0.02 60 /.4) 50%, oklch(13% 0.02 60 /.06) 70%, transparent 84%),
      linear-gradient(0deg, oklch(11% 0.02 60 /.5) 0%, transparent 30%)}

  .hero-wrap{position:absolute;inset:0;z-index:2;display:flex;align-items:center}
  .hero-center{max-width:600px;width:100%}
  .hero-logo{width:min(78vw, 560px);height:auto;display:block;
    filter:brightness(0) invert(1) drop-shadow(0 6px 30px rgba(0,0,0,.55));
    will-change:transform,opacity}
  .hero-kicker{color:var(--color-sun);font-size:clamp(1.4rem,4vw,2.4rem);margin-top:var(--space-md);
    text-shadow:0 2px 14px rgba(0,0,0,.6);line-height:1}
  .hero-tag{font-family:var(--font-head);text-transform:uppercase;letter-spacing:.09em;
    font-size:clamp(.85rem,2.2vw,1.2rem);color:var(--color-paper);margin-top:.6rem;
    text-shadow:0 2px 10px rgba(0,0,0,.6)}

  .hero-scroll{position:absolute;left:50%;bottom:1.4rem;transform:translateX(-50%);z-index:2}
  .hero-scroll-dot{display:block;width:24px;height:38px;border:2px solid var(--color-paper);border-radius:13px;position:relative}
  .hero-scroll-dot::after{content:"";position:absolute;left:50%;top:7px;width:4px;height:7px;
    border-radius:2px;background:var(--color-sun);transform:translateX(-50%);
    animation:scrolldot 1.6s var(--ease-in-out) infinite}
  @keyframes scrolldot{0%{opacity:0;transform:translate(-50%,0)}40%{opacity:1}80%{opacity:0;transform:translate(-50%,13px)}100%{opacity:0}}

  /* mobile: foto centrata sulla band, testo in basso, sfumatura dal basso */
  @media (max-width:680px){
    .hero{align-items:flex-end}
    .hero-img{object-position:62% 38%}
    .hero-scrim{background:
      linear-gradient(0deg, oklch(12% 0.02 60 /.86) 0%, oklch(13% 0.02 60 /.4) 36%, transparent 66%),
      linear-gradient(90deg, oklch(12% 0.02 60 /.4), transparent 70%)}
    .hero-wrap{padding-bottom:clamp(3.5rem,12vh,6rem)}
    .hero-logo{width:min(86vw, 460px)}
  }
  @media (prefers-reduced-motion: reduce){
    .hero-scroll-dot::after{animation:none}
  }
</style>
