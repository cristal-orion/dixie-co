---
// Sezione Contatti.
import { contacts } from '../data/site.js';
---
<section id="contatti" class="section contatti">
  <div class="container contatti-grid">
    <div class="reveal">
      <p class="sec-kicker">facciamo festa</p>
      <h2 class="sec-title contatti-title">Portateci<br/>al vostro evento</h2>
      <p class="sec-lead">Due chiacchiere, una data, e ci pensiamo noi.</p>
    </div>

    <div class="contatti-card reveal">
      <div class="contact-rows">
        {contacts.phones.map((p) => (
          <a class="contact-row" href={p.href}>
            <span class="contact-ico">☎</span>
            <span><b>{p.number}</b><em>{p.name}</em></span>
          </a>
        ))}
        <a class="contact-row" href={contacts.emailHref}>
          <span class="contact-ico">✉</span>
          <span><b>{contacts.email}</b><em>scrivici una mail</em></span>
        </a>
        <div class="contact-row static">
          <span class="contact-ico">⚲</span>
          <span><b>{contacts.place}</b><em>dove ci trovate</em></span>
        </div>
      </div>
      <a class="btn btn-cherry contatti-fb" href={contacts.facebook} target="_blank" rel="noopener">
        Seguici su Facebook
      </a>
    </div>
  </div>
</section>

<style>
  .contatti{background:var(--color-ink);color:var(--color-cream)}
  .contatti .sec-kicker{color:var(--color-sun)}
  .contatti-title{color:var(--color-cream)}
  .contatti .sec-lead{color:oklch(85% 0.02 80)}
  .contatti-grid{display:grid;grid-template-columns:1fr 1fr;gap:var(--space-2xl);align-items:center}
  .contatti-card{background:var(--color-cream);color:var(--color-ink);
    border-radius:var(--radius-lg);padding:var(--space-lg);box-shadow:var(--shadow-lift)}
  .contact-rows{display:flex;flex-direction:column}
  .contact-row{display:flex;align-items:center;gap:var(--space-md);
    padding:var(--space-md) 0;border-bottom:var(--rule-hair) solid oklch(80% 0.02 80);
    min-height:44px;transition:transform var(--dur-fast) var(--ease-out)}
  .contact-row:last-child{border-bottom:none}
  a.contact-row:hover{transform:translateX(4px)}
  .contact-ico{width:44px;height:44px;flex:none;display:grid;place-items:center;
    background:var(--color-cherry);color:var(--color-paper);border-radius:50%;font-size:1.2rem}
  .contact-row b{font-family:var(--font-head);font-size:1.2rem;display:block}
  .contact-row em{font-style:normal;color:var(--color-muted);font-size:.85rem}
  .contatti-fb{margin-top:var(--space-md);width:100%;justify-content:center}

  @media (max-width:820px){.contatti-grid{grid-template-columns:1fr;gap:var(--space-xl)}}
</style>
