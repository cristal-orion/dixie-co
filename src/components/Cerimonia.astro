---
// Sezione Cerimonia & Eventi — card colorate con foto che "sboccia" al hover.
const formazioni = [
  { nome: 'Quartetto', tag: 'la base', tone: 'cherry', img: '/foto/live-2.jpg',
    strumenti: ['piano', 'tromba', 'sax', 'batteria'] },
  { nome: 'Quintetto', tag: 'in più', tone: 'teal', img: '/foto/tromba-basso.jpg',
    strumenti: ['piano', 'tromba', 'sax', 'batteria', 'contrabbasso'] },
  { nome: 'In chiesa', tag: 'il rito', tone: 'ink', img: '/foto/teatro.jpg',
    strumenti: ['violino', 'piano', 'oboe', 'organo', 'arpa', 'voce'] },
];
const momenti = ['Aperitivo', 'Taglio torta', 'Momento danzante', 'Solo alcuni momenti'];
---
<section id="cerimonia" class="section cerimonia">
  <div class="container">
    <div class="sec-head reveal">
      <p class="sec-kicker">il vostro giorno sì</p>
      <h2 class="sec-title">Cerimonie<br/>&amp; eventi</h2>
      <p class="sec-lead">
        Vi accompagniamo dall'aperitivo al taglio torta: dixieland allegro dal vivo,
        e poi un momento danzante con swing, rock'n'roll e twist.
      </p>
    </div>

    <div class="events">
      {formazioni.map((f) => (
        <article class={`ev-card ev-${f.tone} reveal`} tabindex="0">
          <img class="ev-photo" src={f.img} alt={`Formazione: ${f.nome}`} loading="lazy" />
          <span class="ev-veil"></span>
          <span class="ev-stripe"></span>
          <div class="ev-body">
            <span class="ev-tag script">{f.tag}</span>
            <h3 class="ev-name">{f.nome}</h3>
            <p class="ev-list">
              {f.strumenti.map((s, i) => (
                <><span>{s}</span>{i < f.strumenti.length - 1 && <b aria-hidden="true">♪</b>}</>
              ))}
            </p>
          </div>
        </article>
      ))}
    </div>

    <div class="momenti reveal">
      <span class="momenti-label">Su misura per ogni momento</span>
      <div class="momenti-row">
        {momenti.map((m) => <span class="moment-pill">{m}</span>)}
      </div>
      <a href="#contatti" class="btn btn-ink">Chiedi una data</a>
    </div>
  </div>
</section>

<style>
  .cerimonia{background:var(--color-paper)}

  .events{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-md)}
  .ev-card{position:relative;overflow:hidden;border-radius:var(--radius-lg);
    border:3px solid var(--color-ink);min-height:clamp(380px,48vh,480px);
    display:flex;flex-direction:column;justify-content:flex-end;cursor:default;
    box-shadow:var(--shadow-soft);
    transition:transform var(--dur-mid) var(--ease-out),box-shadow var(--dur-mid) var(--ease-out)}
  .ev-card:hover,.ev-card:focus-visible{transform:translateY(-6px) rotate(-.4deg);box-shadow:var(--shadow-lift)}

  .ev-cherry{background:var(--color-cherry)}
  .ev-teal{background:var(--color-teal)}
  .ev-ink{background:var(--color-ink)}

  /* la foto: tenue al riposo (card colorata), sboccia al hover */
  .ev-photo{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;
    opacity:.20;transform:scale(1.03);mix-blend-mode:luminosity;
    transition:opacity var(--dur-slow) var(--ease-out),transform 700ms var(--ease-out),mix-blend-mode 0s}
  .ev-card:hover .ev-photo,.ev-card:focus-visible .ev-photo{opacity:.95;transform:scale(1.08);mix-blend-mode:normal}

  /* velo colorato sul fondo → testo sempre leggibile */
  .ev-veil{position:absolute;inset:0;z-index:1;transition:opacity var(--dur-slow) var(--ease-out)}
  .ev-cherry .ev-veil{background:linear-gradient(180deg, transparent 30%, var(--color-cherry) 94%)}
  .ev-teal .ev-veil{background:linear-gradient(180deg, transparent 30%, var(--color-teal) 94%)}
  .ev-ink .ev-veil{background:linear-gradient(180deg, transparent 22%, var(--color-ink) 92%)}
  .ev-card:hover .ev-veil,.ev-card:focus-visible .ev-veil{opacity:.85}

  /* fascia a righe in cima */
  .ev-stripe{position:absolute;top:0;left:0;right:0;height:8px;z-index:2;background:var(--stripe-thin)}

  .ev-body{position:relative;z-index:3;padding:var(--space-lg);color:var(--color-paper)}
  .ev-tag{font-size:1.5rem;color:var(--color-sun);rotate:-3deg;display:inline-block;margin-bottom:.1rem}
  .ev-name{font-family:var(--font-display);text-transform:uppercase;
    font-size:clamp(1.7rem,3vw,2.6rem);line-height:1;margin-bottom:.7rem;
    text-shadow:0 2px 12px oklch(15% 0 0 /.4)}
  .ev-list{display:flex;flex-wrap:wrap;align-items:baseline;gap:.3rem .5rem;
    font-family:var(--font-head);text-transform:lowercase;font-size:1rem}
  .ev-list b{color:var(--color-sun);font-size:.7em}

  .momenti{margin-top:var(--space-xl);text-align:center;
    background:var(--color-cream);border:3px solid var(--color-ink);
    border-radius:var(--radius-lg);padding:var(--space-xl)}
  .momenti-label{font-family:var(--font-head);font-size:var(--text-xl);display:block;margin-bottom:var(--space-md)}
  .momenti-row{display:flex;flex-wrap:wrap;gap:.6rem;justify-content:center;margin-bottom:var(--space-lg)}
  .moment-pill{font-family:var(--font-body);font-weight:600;font-size:.9rem;
    background:var(--color-sun);color:var(--color-ink);padding:.5em 1.1em;border-radius:var(--radius-pill)}

  @media (max-width:820px){
    .events{grid-template-columns:1fr;gap:var(--space-md)}
    .ev-card{min-height:300px}
    /* su mobile niente hover: foto già un po' più presente */
    .ev-photo{opacity:.34}
  }
  @media (prefers-reduced-motion: reduce){
    .ev-photo,.ev-veil,.ev-card{transition-duration:.001ms}
  }
</style>
