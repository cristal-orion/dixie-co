---
import '../styles/global.css';
import { band, contacts } from '../data/site.js';

const {
  title = 'Dixie & Co. — Jazz · Swing · Dixieland Band, Salerno',
  description = 'Dixie & Co.: jazz, swing e dixieland dal vivo a Salerno. Bretelle rosse, cappelli di paglia e tanta allegria. Eventi, cerimonie e concerti.',
  image = '/foto/anteprima.jpg',
} = Astro.props;

// URL assoluti: WhatsApp/Telegram/iMessage richiedono URL completi per l'anteprima
const site = Astro.site.href.replace(/\/$/, '');
const ogImage = new URL(image, Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// Dati strutturati MusicGroup — rich results Google + comprensione motori AI (GEO)
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicGroup',
  name: band.name,
  alternateName: 'Dixie and Co.',
  genre: ['Jazz', 'Swing', 'Dixieland', 'New Orleans Jazz'],
  foundingDate: band.founded,
  foundingLocation: { '@type': 'Place', name: 'Salerno, Italia' },
  url: site,
  image: ogImage,
  logo: `${site}/img/logo-wordmark.png`,
  description,
  email: contacts.email,
  telephone: contacts.phones[0].href.replace('tel:', ''),
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Piazza XXIV Maggio',
    addressLocality: 'Salerno',
    addressRegion: 'SA',
    postalCode: '84121',
    addressCountry: 'IT',
  },
  areaServed: ['Salerno', 'Napoli', 'Costiera Amalfitana', 'Ravello', 'Amalfi', 'Roma', 'Pisa', 'Livorno'],
  sameAs: [contacts.facebook],
};
---
<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Geo / local SEO (Salerno) -->
  <meta name="geo.region" content="IT-SA" />
  <meta name="geo.placename" content="Salerno" />
  <meta name="geo.position" content="40.6803;14.7594" />
  <meta name="ICBM" content="40.6803, 14.7594" />

  <!-- Open Graph (WhatsApp, Telegram, Facebook, LinkedIn) -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Dixie & Co." />
  <meta property="og:locale" content="it_IT" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:secure_url" content={ogImage} />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="789" />
  <meta property="og:image:alt" content="Dixie & Co. dal vivo" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <meta name="theme-color" content="#FBF1DC" />
  <link rel="icon" type="image/png" href="/img/badge-disco.png" />
  <link rel="apple-touch-icon" href="/img/badge-disco.png" />

  <!-- Dati strutturati MusicGroup -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Alfa+Slab+One&family=Lilita+One&family=Pacifico&family=Poppins:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body>
  <a id="top"></a>
  <slot />

  <script>
    // reveal-on-scroll
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
  </script>
</body>
</html>
